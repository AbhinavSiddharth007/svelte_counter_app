{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "extends": ["eslint:recommended", "prettier", "plugin:storybook/recommended"],
  "plugins": ["svelte"],
  "ignorePatterns": [
    ".svelte-kit/",
    "build/",
    ".storybook/",
    "src/stories/",
    "playwright-report/",
    "test-results/"
  ],
  "overrides": [
    {
      "files": ["*.svelte", "**/*.svelte"],
      "parser": "svelte-eslint-parser",
      "processor": "svelte/svelte"
    }
  ],
  "rules": {
    "no-inner-declarations": "off",
    "no-unused-vars": "warn",
    "no-console": "warn"
  }
}
