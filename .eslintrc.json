{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "extends": ["eslint:recommended", "prettier"],
  "plugins": ["svelte"],
  "ignorePatterns": [".svelte-kit/", "build/"],
  "overrides": [
    {
      "files": ["*.svelte", "**/*.svelte"],
      "parser": "svelte-eslint-parser",
      "processor": "svelte/svelte"
    }
  ],
  "rules": {
    "no-inner-declarations": "off",
    "no-unused-vars": "warn",
    "no-console": "warn"
  }
}
